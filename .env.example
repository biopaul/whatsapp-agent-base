# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: waha | whapi | meta | twilio
WHATSAPP_PROVIDER=waha

# ── WAHA (default) ───────────────────────────────────────
# Self-hosted WhatsApp HTTP API — https://waha.devlike.pro
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION=default

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
# WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Config remota (inyectado por el orquestador) ─────────
# Si esta vacio, usa config/prompts.yaml y config/business.yaml locales
# CONFIG_URL=https://example.com/wp-json/gowap/v1/config/token_here
# CONFIG_CACHE_TTL=300

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Handoff humano-IA ─────────────────────────────────────
# Consultar el plugin WP para saber si un chat esta en manual mode.
# Si esta vacio, el modulo opera en no-op (siempre auto).
# TAKEOVER_URL_BASE=https://wp.example.com/wp-json/gowap/v1/takeover/abc123

# Opcionales (defaults entre parentesis)
# TAKEOVER_POLL_AUTO_TTL=30          # segundos de cache para mode=auto (30)
# TAKEOVER_AWARENESS_LOOKBACK=60     # minutos del window de awareness (60)
# TAKEOVER_HTTP_TIMEOUT=5            # timeout HTTP del cliente (5)

# ── Respuestas Guiadas ────────────────────────────────────
# Endpoint del plugin para fetchear plantillas activas + tracking.
# Si esta vacio, el modulo opera en no-op (sin plantillas).
# GUIDED_URL_BASE=https://wp.example.com/wp-json/gowap/v1/guided/abc123

# Opcionales (defaults entre parentesis)
# GUIDED_CACHE_TTL=300                # segundos de cache de plantillas (300)
# GUIDED_SELECTION_WINDOW_MIN=10      # minutos de ventana de seleccion (10)
# GUIDED_HTTP_TIMEOUT=5               # timeout HTTP del cliente (5)
