# WhatsApp Agent Base — Variables de entorno
# Copiar a .env y completar con los valores del cliente
# NUNCA subir .env a GitHub

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Proveedor de WhatsApp (whapi | meta | twilio)
WHATSAPP_PROVIDER=whapi

# Whapi.cloud
WHAPI_TOKEN=...

# Meta Cloud API (si WHATSAPP_PROVIDER=meta)
# META_ACCESS_TOKEN=...
# META_PHONE_NUMBER_ID=...
# META_VERIFY_TOKEN=...

# Twilio (si WHATSAPP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=...

# Servidor
PORT=8000
ENVIRONMENT=development

# Base de datos
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
