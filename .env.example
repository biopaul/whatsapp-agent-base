# WhatsApp Agent Base — Variables de entorno
# Copiar a .env y completar con los valores del cliente
# NUNCA subir .env a GitHub

# Proveedor de IA (claude | openai | gemini) — default: claude
AI_PROVIDER=claude

# Modelo a usar — dejar vacío para usar el default de cada proveedor
# Claude defaults:  claude-haiku-4-5-20251001 (barato) / claude-sonnet-4-6 (mejor)
# OpenAI defaults:  gpt-4o-mini (barato) / gpt-4o (mejor)
# Gemini defaults:  gemini-2.0-flash (barato) / gemini-2.0-pro (mejor)
# AI_MODEL=

# API Keys — solo completar la del proveedor elegido
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Proveedor de WhatsApp (waha | whapi | meta | twilio)
WHATSAPP_PROVIDER=waha

# WAHA — self-hosted WhatsApp HTTP API (default)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION=default

# Whapi.cloud (si WHATSAPP_PROVIDER=whapi)
# WHAPI_TOKEN=...

# Meta Cloud API (si WHATSAPP_PROVIDER=meta)
# META_ACCESS_TOKEN=...
# META_PHONE_NUMBER_ID=...
# META_VERIFY_TOKEN=...

# Twilio (si WHATSAPP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=...

# Notificaciones — número que recibe alertas cuando el bot escala a humano
# Formato internacional sin +, ej: 5491155554444
# Dejar vacío para deshabilitar notificaciones
NOTIFY_PHONE=
# Nombre de la persona que recibe las alertas (hace el mensaje más personal)
NOTIFY_NAME=

# Config remota (inyectado por el orquestador, no completar manualmente)
# Si esta vacio, usa config/prompts.yaml y config/business.yaml locales
# CONFIG_URL=https://example.com/wp-json/gowap/v1/config/token_here
# CONFIG_CACHE_TTL=300

# Servidor
PORT=8000
ENVIRONMENT=development

# Base de datos
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
